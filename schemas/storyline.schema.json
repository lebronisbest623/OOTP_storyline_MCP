{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ootp-storyline.schema.json",
  "title": "OOTP Storyline Project",
  "type": "object",
  "required": ["id", "random_frequency", "required_data", "articles"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "random_frequency": { "type": "integer", "minimum": 1 },
    "trigger_events": { "type": "string" },
    "is_minor_league": { "type": "boolean" },
    "only_in_season": { "type": "boolean" },
    "only_in_offseason": { "type": "boolean" },
    "only_in_spring": { "type": "boolean" },
    "league_year_min": { "type": "integer" },
    "league_year_max": { "type": "integer" },
    "min_usage_interval_days": { "type": "integer", "minimum": 0 },
    "storyline_happens_only_once": { "type": "boolean" },
    "required_data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" },
          "main_actor": { "type": "boolean" }
        },
        "additionalProperties": {
          "type": ["string", "integer", "boolean"]
        }
      }
    },
    "articles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "subject", "text"],
        "properties": {
          "id": { "type": "integer" },
          "subject": { "type": "string" },
          "text": { "type": "string" },
          "injury_description": { "type": "string" }
        },
        "additionalProperties": {
          "type": ["string", "integer", "boolean"]
        }
      }
    }
  },
  "additionalProperties": {
    "type": ["string", "integer", "boolean"]
  }
}
